---
import Base from '../layouts/Base.astro';
import SectionHero from './SectionHero.astro';
import PostRow from './PostRow.astro';
import { t, type Locale } from '../i18n/ui';
import { getPosts } from '../lib/posts';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const posts = await getPosts('essays');

function roman(n: number): string {
  const table: [number, string][] = [
    [40, 'XL'], [10, 'X'], [9, 'IX'], [5, 'V'], [4, 'IV'], [1, 'I'],
  ];
  let out = '';
  for (const [value, glyph] of table) {
    while (n >= value) {
      out += glyph;
      n -= value;
    }
  }
  return out;
}

// 악장 번호: 가장 오래된 글이 I.
const numbered = posts.map((post, i) => ({ post, no: roman(posts.length - i) }));
---

<Base locale={locale} title={t(locale, 'nav.essays')} description={t(locale, 'essays.desc')}>
  <SectionHero
    title={t(locale, 'nav.essays')}
    ornament={t(locale, 'essays.subtitle')}
    description={t(locale, 'essays.desc')}
  />

  {numbered.length === 0 && <p class="ornament tacet">— tacet —</p>}

  <ul class="posts">
    {numbered.map(({ post, no }) => (
      <PostRow locale={locale} section="essays" post={post} prefix={`${no}.`} />
    ))}
  </ul>
</Base>

<style>
  .posts {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .tacet {
    text-align: center;
    padding: 3rem 0;
  }
</style>
