---
interface Props {
  title: string;
  ornament?: string;
  description?: string;
}

const { title, ornament, description } = Astro.props;
---

<header class="section-hero">
  <h1>
    {title}
    {ornament && <span class="ornament"> — {ornament}</span>}
  </h1>
  {description && <p class="desc">{description}</p>}
</header>

<style>
  .section-hero {
    padding-top: 2.2rem;
    border-bottom: 1px solid var(--line);
    padding-bottom: 1.2rem;
  }

  h1 {
    margin: 0;
  }

  .ornament {
    font-size: 0.65em;
  }

  .desc {
    color: var(--muted);
    font-size: 0.92rem;
    margin: 0.6rem 0 0;
    word-break: keep-all;
  }
</style>
