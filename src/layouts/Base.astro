---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { t, type Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
  wide?: boolean;
}

const { locale, title, description, wide = false } = Astro.props;
const pageTitle = title ? `${title} · ${t(locale, 'site.title')}` : t(locale, 'site.title');
const pageDesc = description ?? t(locale, 'site.description');
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:type" content="website" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title={t(locale, 'site.title')} href="/rss.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=IBM+Plex+Sans+KR:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&family=Noto+Serif+KR:wght@400;500&display=swap"
    />
  </head>
  <body>
    <Header locale={locale} />
    <main class:list={[{ wide }]}>
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
